# PPP-Blog environment template
# Copy to .env and fill real values. Never commit .env.

# =========================
# Core services
# =========================
MYSQL_ROOT_PASSWORD=your_strong_root_password_here
MYSQL_DATABASE=halo
MYSQL_USER=halo
MYSQL_PASSWORD=your_strong_mysql_password_here
MYSQL_HOST_PORT=3307

REDIS_PASSWORD=your_strong_redis_password_here

HALO_EXTERNAL_URL=https://your-domain.com
# Keep memory conservative on 3C3G servers. Optional SkyWalking javaagent can be appended.
HALO_JVM_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC -XX:MaxRAMPercentage=75.0
SW_AGENT_NAME=halo
SW_AGENT_COLLECTOR_BACKEND_SERVICES=skywalking-oap:11800
# Example with SkyWalking Java agent:
# HALO_JVM_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC -XX:MaxRAMPercentage=75.0 -javaagent:/opt/skywalking/agent/skywalking-agent.jar

# =========================
# Deployment basics
# =========================
SERVER_HOST=your_server_ip
SSH_PORT=22
BACKUP_RETENTION_DAYS=7

# =========================
# MiniMax AI (comment moderation + auto reply)
# =========================
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_URL=https://api.minimaxi.com/anthropic/v1/messages
MINIMAX_MODEL=MiniMax-M2.5

COMMENT_REVIEW_AI_ENABLED=true
COMMENT_REVIEW_AI_TIMEOUT_SECONDS=30
COMMENT_REVIEW_AI_MAX_CONTENT_CHARS=500

AUTO_REPLY_AI_ENABLED=true
AUTO_REPLY_AI_TIMEOUT_SECONDS=30
AUTO_REPLY_MAX_COMMENT_CHARS=180
AUTO_REPLY_MAX_REPLY_CHARS=120
AUTO_REPLY_DAILY_CALL_LIMIT=300
AUTO_REPLY_DAILY_AUTHOR_LIMIT=20
AUTO_REPLY_AUTHOR_COOLDOWN_SECONDS=60

# =========================
# Grafana alerting (optional)
# =========================
GF_SECURITY_ADMIN_PASSWORD=change_me
GF_SMTP_ENABLED=false
GF_SMTP_HOST=
GF_SMTP_USER=
GF_SMTP_PASSWORD=
GF_SMTP_FROM_ADDRESS=
GF_SMTP_FROM_NAME=PPP-Blog Alert

# =========================
# server-monitor webhook (optional)
# =========================
WEBHOOK_URL=
